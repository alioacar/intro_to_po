import pandas as pd
import numpy as np
from pyproj import CRS, Transformer
from bokeh.plotting import figure
from bokeh.tile_providers import get_provider, ESRI_IMAGERY
from bokeh.io import output_notebook, show
from bokeh.models import ColumnDataSource
import warnings

warnings.filterwarnings("ignore")
output_notebook()

# Load the data
stations = pd.read_csv('../_static/data/HMSChallenger-Station-Data.csv')

# Convert latitude and longitude to decimal degrees
lat = stations['Latitude Degrees'] + stations['Latitude Minutes'] / 60. + stations['Latitude Seconds'] / 3600.
lon = stations['Longitude Degrees'] + stations['Longitude Minutes'] / 60. + stations['Longitude Seconds'] / 3600.

# Apply direction adjustments
lat[stations['North/South'] == 'S'] *= -1
lon[stations['East/West'] == 'W'] *= -1

# Initialize projection
esri = get_provider(ESRI_IMAGERY)
inProj = CRS.from_epsg(3857)  # Web Mercator
outProj = CRS.from_epsg(4326)  # WGS 84

# Create a transformer
transformer = Transformer.from_crs(outProj, inProj, always_xy=True)

# Define the map boundaries
world_lon1, world_lat1 = transformer.transform(-175, -80)
world_lon2, world_lat2 = transformer.transform(175, 80)

# Convert lat/lon to Mercator projection
lons, lats = transformer.transform(lon.values, lat.values)

# Create a ColumnDataSource including Location
source = ColumnDataSource(data=dict(
    lons=lons,
    lats=lats,
    lat=lat,
    lon=lon,
    location=stations['Location']  # Add the Location data
))

# Create the plot
p = figure(width=800, height=700,
           x_range=(world_lon1, world_lon2), y_range=(world_lat1, world_lat2),
           x_axis_type="mercator", y_axis_type="mercator",
           tools="box_zoom, reset, save, hover",
           title="HMS Challenger Track")

# Add tile and circles
p.add_tile(esri)
p.circle(x='lons', y='lats', source=source, size=6,
         fill_color="red", line_color="red", fill_alpha=0.3)

# Customize tooltips to include Location
p.hover.tooltips = [
    ("Location", "@location"),
    ("Longitude", "@lon{0.0}"),
    ("Latitude", "@lat{0.0}")
]

# Show the plot
show(p)

